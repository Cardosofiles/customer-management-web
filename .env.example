# ╔══════════════════════════════════════════════════╗
# ║              🐘 POSTGRESQL DATABASE              ║
# ╚══════════════════════════════════════════════════╝

# Nome do container Docker do PostgreSQL
POSTGRES_CONTAINER_NAME=

# Porta exposta pelo container do PostgreSQL
POSTGRES_PORT=

# Nome do banco de dados a ser criado/utilizado
POSTGRES_DB=

# Usuário administrador do banco de dados
POSTGRES_USER=

# Senha do usuário administrador do banco de dados
POSTGRES_PASSWORD=

# Caminho do volume de dados persistente do PostgreSQL
POSTGRES_PGDATA=


# ╔══════════════════════════════════════════════════╗
# ║                  🖥️ PGADMIN                      ║
# ╚══════════════════════════════════════════════════╝

# Nome do container Docker do PgAdmin
PGADMIN_CONTAINER_NAME=

# Porta exposta pelo container do PgAdmin
PGADMIN_PORT=

# E-mail de acesso padrão ao painel do PgAdmin
PGADMIN_DEFAULT_EMAIL=

# Senha de acesso padrão ao painel do PgAdmin
PGADMIN_DEFAULT_PASSWORD=


# ╔══════════════════════════════════════════════════╗
# ║              🔌 DATABASE CONNECTION              ║
# ╚══════════════════════════════════════════════════╝

# URL de conexão completa com o banco de dados (usada pelo Prisma/JPA)
# Formato: postgresql://USER:PASSWORD@HOST:PORT/DATABASE
DATABASE_URL=


# ╔══════════════════════════════════════════════════╗
# ║                 📧 RESEND (EMAIL)                ║
# ╚══════════════════════════════════════════════════╝

# Chave de API do serviço Resend para envio de e-mails
RESEND_API_KEY=key

# Endereço de e-mail remetente (ex: noreply@seudominio.com)
RESEND_FROM=from-email


# ╔══════════════════════════════════════════════════╗
# ║                🔐 BETTER AUTH                    ║
# ╚══════════════════════════════════════════════════╝

# URL pública da aplicação utilizada pelo Better Auth no cliente
NEXT_PUBLIC_BETTER_AUTH_URL=

# URL base da aplicação utilizada pelo Better Auth no servidor
BETTER_AUTH_URL=

# Segredo utilizado para assinar tokens e sessões do Better Auth
# Gere com: openssl rand -base64 32
BETTER_AUTH_SECRET=


# ╔══════════════════════════════════════════════════╗
# ║            🌐 OAUTH PROVIDERS                    ║
# ╚══════════════════════════════════════════════════╝

# --- Google ---
# Client ID do projeto no Google Cloud Console
GOOGLE_CLIENT_ID=
# Client Secret do projeto no Google Cloud Console
GOOGLE_CLIENT_SECRET=

# --- GitHub ---
# Client ID do OAuth App no GitHub Developer Settings
GITHUB_CLIENT_ID=
# Client Secret do OAuth App no GitHub Developer Settings
GITHUB_CLIENT_SECRET=

